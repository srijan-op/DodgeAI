NEO4J_USER="your_neo4j_user" #neo4j default user is "neo4j"
NEO4J_PASSWORD="your_neo4j_password"
# Local dev: bolt://localhost:7687 | Docker Compose: set in compose (bolt://neo4j:7687), not required in .env
NEO4J_URI="bolt://localhost:7687"
NEO4J_DATABASE=neo4j

# Redis (optional). Docker Compose sets REDIS_URL to redis://redis:6379/0 automatically.
REDIS_URL=

# Browser origins allowed to call the API (include your frontend URL). Docker UI default:
# CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

GROQ_API_KEY_1="your_groq_api_key_1" #primary call

GROQ_API_KEY_2="your_groq_api_key_2" #secondary call (fallback)